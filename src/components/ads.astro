---
// ==========================================
// 1. SHARED TYPES
// ==========================================
interface BaseProps {
  class?: string;
  style?: string;
  /** If true, blocks analytics domains (like Ruslan's senty.com.au) via CSP. */
  blockAnalytics?: boolean;
}

type SecurityLevel = 'none' | 'balanced' | 'strict';

// ==========================================
// 2. ADSENSE TYPES
// ==========================================
interface AdsenseHeadProps extends BaseProps {
  type: 'adsense';
  location: 'head';
  client?: string;
  slot?: never; format?: never; fullWidthResponsive?: never; layoutKey?: never; layout?: never; adTest?: never;
  key?: never; src?: never; securityLevel?: never;
}

interface AdsenseBodyProps extends BaseProps {
  type: 'adsense';
  location: 'body';
  client?: string;
  slot: string;
  format?: 'auto' | 'rectangle' | 'vertical' | 'horizontal' | 'fluid';
  fullWidthResponsive?: boolean;
  layoutKey?: string;
  layout?: 'in-article';
  adTest?: 'on' | 'off';
  key?: never; src?: never; securityLevel?: never;
}

// ==========================================
// 3. ADSTERRA TYPES
// ==========================================
interface AdsterraBannerProps extends BaseProps {
  type: 'adsterra';
  format: 'iframe';
  location: 'body';
  key: string;
  height: number;
  width: number;
  /** * Custom targeting parameters.
   * Maps to '&custom={"key":"value"}' in the ad request.
   */
  params?: Record<string, string | number>;
  securityLevel?: SecurityLevel;
  src?: never; slot?: never;
}

interface AdsterraScriptProps extends BaseProps {
  type: 'adsterra';
  format: 'script';
  location: 'head' | 'body';
  src: string;
  key?: never; slot?: never; securityLevel?: 'none'; params?: never;
}

// ==========================================
// 4. RUSLAN TYPES
// ==========================================
interface RuslanProps extends BaseProps {
  type: 'ruslan';
  location: 'body';
  key?: never; slot?: never; securityLevel?: 'none'; params?: never;
}

export type Props = AdsenseHeadProps | AdsenseBodyProps | AdsterraBannerProps | AdsterraScriptProps | RuslanProps;

const props = Astro.props as Props;
const { type, location } = props;
const blockAnalytics = props.blockAnalytics || false;

const DEFAULT_CLIENT = "ca-pub-6640595376330309";

// ==========================================
// CSP LOGIC (Unchanged from previous)
// ==========================================
if (type === 'adsense') {
  Astro.csp.insertScriptResource("https://pagead2.googlesyndication.com");
  Astro.csp.insertDirective("frame-src https://googleads.g.doubleclick.net https://tpc.googlesyndication.com https://www.google.com");
  Astro.csp.insertDirective("connect-src https://pagead2.googlesyndication.com");
}

if (type === 'adsterra') {
  const isSandboxed = props.format === 'iframe' && (props.securityLevel === 'balanced' || props.securityLevel === 'strict');

  Astro.csp.insertScriptResource("https://www.highperformanceformat.com");
  Astro.csp.insertScriptResource("https://pl27983175.effectivegatecpm.com");

  if (!blockAnalytics && !isSandboxed) {
    const maliciousDomains = [
      "https://skinnycrawlinglax.com",
      "https://wayfarerorthodox.com",
      "https://protrafficinspector.com"
    ];
    Astro.csp.insertDirective(`connect-src ${maliciousDomains.join(" ")}`);
  }
}

if (type === 'ruslan') {
  Astro.csp.insertScriptResource("https://cdn.jsdelivr.net");
  if (!blockAnalytics) {
    Astro.csp.insertScriptResource("https://stats.senty.com.au");
    Astro.csp.insertDirective("connect-src https://stats.senty.com.au");
  }
}

const getSandboxRules = (level: SecurityLevel) => {
  const base = "allow-scripts allow-popups allow-forms";
  if (level === 'strict') return base;
  if (level === 'balanced') return `${base} allow-same-origin`;
  return undefined;
};

const getPermissionPolicy = () => {
  return [
    "accelerometer 'none'", "camera 'none'", "geolocation 'none'", "gyroscope 'none'",
    "magnetometer 'none'", "microphone 'none'", "payment 'none'", "usb 'none'", "interest-cohort 'none'"
  ].join('; ');
};
---

{/* HEAD RENDERER */}
{location === 'head' && (
  <>
    {type === 'adsense' && (
      <>
        <meta name="google-adsense-account" content={props.client || DEFAULT_CLIENT} />
        <script type="text/partytown" async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${props.client || DEFAULT_CLIENT}`} crossorigin="anonymous" />
      </>
    )}
    {type === 'adsterra' && props.format === 'script' && (
      <script type="text/partytown" src={props.src} />
    )}
  </>
)}

{/* BODY RENDERER */}
{location === 'body' && (
  <div class={`ad-wrapper ${props.class || ''}`} style={props.style}>

    {/* ADSENSE */}
    {type === 'adsense' && (
      <>
        <ins
          class="adsbygoogle" style="display:block"
          data-ad-client={props.client || DEFAULT_CLIENT}
          data-ad-slot={props.slot}
          data-ad-format={props.format || "auto"}
          data-full-width-responsive={props.fullWidthResponsive !== false ? "true" : "false"}
          data-ad-layout-key={props.layoutKey} data-ad-layout={props.layout} data-adtest={props.adTest}
        />
        <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </>
    )}

    {/* ADSTERRA BANNER */}
    {type === 'adsterra' && props.format === 'iframe' && (
      <>
        {/* MODE 1: DIRECT (Unsafe) */}
        {(!props.securityLevel || props.securityLevel === 'none') && (
          <>
            <script is:inline define:vars={{
                k: props.key, w: props.width, h: props.height, p: props.params || {}
            }}>
              window.atOptions = { 'key': k, 'format': 'iframe', 'height': h, 'width': w, 'params': p };
            </script>
            <script type="text/partytown" src={`//www.highperformanceformat.com/${props.key}/invoke.js`} />

            {props.key === '0780c0040cb8d0fac1fb974a70a71024' && (
              <script type="text/partytown">if (typeof aclib !== 'undefined') aclib.runAutoTag({ zoneId: 'pifa6if29m' });</script>
            )}
          </>
        )}

        {/* MODE 2: SANDBOXED (Balanced/Strict) */}
        {(props.securityLevel === 'balanced' || props.securityLevel === 'strict') && (
          <iframe
            title="Advertisement"
            width={props.width}
            height={props.height}
            frameborder="0"
            scrolling="no"
            loading="lazy"
            sandbox={getSandboxRules(props.securityLevel)}
            allow={getPermissionPolicy()}
            srcdoc={`
              <!DOCTYPE html>
              <html>
              <head><style>body{margin:0;padding:0;overflow:hidden;}</style></head>
              <body>
                <script>
                  window.atOptions = {
                    'key': '${props.key}',
                    'format': 'iframe',
                    'height': ${props.height},
                    'width': ${props.width},
                    'params': ${JSON.stringify(props.params || {})}
                  };
                </script>
                <script src="//www.highperformanceformat.com/${props.key}/invoke.js"></script>
              </body>
              </html>
            `}
            style="border:0; overflow:hidden;"
          ></iframe>
        )}
      </>
    )}

    {/* ADSTERRA SCRIPT */}
    {type === 'adsterra' && props.format === 'script' && (
      <script type="text/partytown" src={props.src} />
    )}

    {/* RUSLAN */}
    {type === 'ruslan' && (
      <script type="text/partytown" src="https://cdn.jsdelivr.net/gh/docklib/partners@master/partner-a11f34f2.js" />
    )}
  </div>
)}
