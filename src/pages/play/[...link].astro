---
import Layout from '../../layouts/AppLayout.astro';
const raw = Astro.params.link ?? 'Unavailable';
const loc = '/' + raw.replace(/^\/+/, '');
Astro.csp.insertDirective(`frame-src ${loc}`);
---

<Layout title={`Embed of ${loc.toString()}`} description="Embed game in iframe">
  <style>
    :root {
      /* Full viewport minus a small margin for aesthetics */
      --app-width: 98dvw;
      --app-height: 98dvh;
    }

    body {
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100dvh;
      margin: 0;
      background-color: #0a1d37;
      color: white;
      font-family: 'Poppins', sans-serif;
      padding: 0;
      overflow: hidden;
    }

    /* --- Background Effects --- */
    .god-rays {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 550px;
      --stripes: repeating-linear-gradient(
        100deg,
        rgba(20, 40, 60, 0.8) 0%,
        rgba(20, 40, 60, 0.8) 7%,
        transparent 10%,
        transparent 12%,
        rgba(20, 40, 60, 0.8) 16%
      );
      --rays: repeating-linear-gradient(
        100deg,
        rgba(30, 50, 90, 0.9) 10%,
        rgba(20, 40, 80, 0.9) 15%,
        rgba(30, 50, 90, 0.9) 20%,
        rgba(20, 40, 80, 0.9) 25%,
        rgba(30, 50, 90, 0.9) 30%
      );
      background-image: var(--stripes), var(--rays);
      background-size: 300%, 200%;
      background-position: 50% 50%;
      animation: fadeIn 2s ease;
      mask-image: radial-gradient(ellipse at 100% 0%, rgba(255, 255, 255, 0) 40%, transparent 70%);
      pointer-events: none;
      z-index: -1;
    }

    /* --- Main Container --- */
    .container-iframe {
      display: flex;
      flex-direction: column; /* Stack Game on top of Controls */
      width: var(--app-width);
      height: var(--app-height);
      z-index: 99;
      gap: 0;
    }

    /* --- Top Section: Game (90dvh) --- */
    .iframe-container {
      position: relative;
      width: 100%;
      /* Exact 90% of the viewport height */
      height: 90dvh;
      flex-shrink: 0;
      border-radius: 20px 20px 0 0; /* Round top corners only */
      overflow: hidden;
      box-shadow: 0 0 30px rgba(0, 0, 0, 0.6);
      border: 4px solid #1a2332;
      border-bottom: none; /* Merge visually with controls */
      background-color: #000;
    }

    .iframe-wrapper {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      transform-origin: 0 0;
      transition: transform 0.2s ease;
    }

    iframe {
      width: 100%;
      height: 100%;
      background-color: #fff;
      border: none;
      display: block;
    }

    /* --- Bottom Section: Controls (10dvh) --- */
    .controls-wrapper {
      width: 100%;
      /* Exact 10% of the viewport height */
      height: 8dvh; /* A bit smaller than 10 so it doesn't touch edges perfectly */
      min-height: 50px;

      background-color: #1a2332; /* Match border color */
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 20px;
      box-sizing: border-box;
      border-radius: 0 0 20px 20px; /* Round bottom corners */
      border: 4px solid #1a2332;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .controls-left,
    .controls-right {
      display: flex;
      gap: 10px;
      height: 100%;
      align-items: center;
    }

    .control-btn {
      background-color: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 0 16px;
      height: 70%; /* Relative to the 10dvh bar */
      color: #fff;
      transition: all 0.2s ease;
      white-space: nowrap;
    }

    .control-btn:hover {
      background-color: rgba(255, 255, 255, 0.15);
      transform: translateY(-2px);
    }

    .control-btn svg {
      flex-shrink: 0;
    }

    /* --- Responsive Text Hiding --- */
    .btn-text {
      font-size: 0.9rem;
      font-weight: 500;
    }

    /* Mobile: Hide text, Icon only */
    @media (max-width: 768px) {
      .btn-text {
        display: none;
      }
      .control-btn {
        padding: 0 12px; /* Smaller padding for icon-only */
      }
    }
  </style>

  <div class="god-rays"></div>

  <div class="container-iframe">
    <div class="iframe-container">
      <div class="iframe-wrapper" id="iframeWrapper">
        <iframe sandbox="allow-scripts allow-pointer-lock allow-forms allow-downloads" id="myIframe" src={loc.toString()}></iframe>
      </div>
    </div>

    <div class="controls-wrapper">
      <div class="controls-left">
        <div class="control-btn" onclick="window.open(document.getElementById('myIframe').src, '_blank')">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
            <polyline points="15 3 21 3 21 9"></polyline>
            <line x1="10" y1="14" x2="21" y2="3"></line>
          </svg>
          <span class="btn-text">Open New Tab</span>
        </div>
      </div>

      <div class="controls-right">
        <div class="control-btn" onclick="performZoomIn()">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            <line x1="11" y1="8" x2="11" y2="14"></line>
            <line x1="8" y1="11" x2="14" y2="11"></line>
          </svg>
          <span class="btn-text">Zoom In</span>
        </div>

        <div class="control-btn" onclick="performZoomOut()">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            <line x1="8" y1="11" x2="14" y2="11"></line>
          </svg>
          <span class="btn-text">Zoom Out</span>
        </div>

        <div class="control-btn" onclick="performFullscreen()">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path>
          </svg>
          <span class="btn-text">Fullscreen</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    let currentZoom = 1;

    window.performZoomIn = function () {
      const wrapper = document.getElementById('iframeWrapper');
      const container = document.querySelector('.iframe-container');
      if (!wrapper || !container) return;

      currentZoom = Math.min(currentZoom + 0.25, 2);

      // When zooming, we adjust the wrapper size relative to the zoom
      const newWidth = container.offsetWidth / currentZoom;
      const newHeight = container.offsetHeight / currentZoom;

      wrapper.style.transform = `scale(${currentZoom})`;
      wrapper.style.width = newWidth + 'px';
      wrapper.style.height = newHeight + 'px';

      container.style.overflow = 'auto';
    };

    window.performZoomOut = function () {
      const wrapper = document.getElementById('iframeWrapper');
      const container = document.querySelector('.iframe-container');
      if (!wrapper || !container) return;

      currentZoom = Math.max(currentZoom - 0.25, 0.5);

      const newWidth = container.offsetWidth / currentZoom;
      const newHeight = container.offsetHeight / currentZoom;

      wrapper.style.transform = `scale(${currentZoom})`;
      wrapper.style.width = newWidth + 'px';
      wrapper.style.height = newHeight + 'px';

      if (currentZoom === 1) {
        container.style.overflow = 'hidden';
        // Reset width/height to ensure responsiveness
        wrapper.style.width = '100%';
        wrapper.style.height = '100%';
      }
    };

    window.performFullscreen = function () {
      const container = document.querySelector('.iframe-container');
      if (!container) return;

      if (document.fullscreenElement) {
        document.exitFullscreen();
      } else {
        container.requestFullscreen().catch((err) => {
          console.error('Fullscreen error:', err);
        });
      }
    };
  </script>
  <script type="text/javascript" src="//www.highperformanceformat.com/fee48967b89db2d0bd32a6c670ffa744/invoke.js"></script>
</Layout>
