---
import controllerUrl from '@petezah-games/scramjet-controller?url';
import wasmPath from '@petezah-games/scramjet/wasm?url';
import scramjetPath from '@petezah-games/scramjet-controller?url';
import sjInject from '@petezah-games/scramjet-controller/inject?url';
import AppLayout from '../../layouts/Layout.astro';

const { target } = Astro.params;
let computedURL: string = '';

// --- Blocklist Logic ---
let cachedList: Set<string> | null = null;
let cachedAt = 0;
const CACHE_DURATION = 2 * 60 * 60 * 1000;

async function getBlockedDomains() {
  const now = Date.now();
  if (cachedList && now - cachedAt < CACHE_DURATION) return cachedList;

  try {
    const response = await fetch('https://raw.githubusercontent.com/StevenBlack/hosts/master/alternates/gambling-porn/hosts');
    const text = await response.text();
    const domains = new Set<string>();

    for (const line of text.split('\n')) {
      const trimmed = line.trim();
      if (!trimmed || trimmed.startsWith('#')) continue;
      const parts = trimmed.split(/\s+/);
      if (parts.length >= 2 && (parts[0] === '0.0.0.0' || parts[0] === '127.0.0.1')) {
        domains.add(parts[1].toLowerCase());
      }
    }
    cachedList = domains;
    cachedAt = now;
    return domains;
  } catch (e) {
    console.error('Failed to fetch blocklist', e);
    return new Set<string>();
  }
}

// --- Route Validation ---
try {
  if (!target) throw new Error('No target specified');

  const decoded = decodeURIComponent(target);
  const parsed = new URL(decoded);

  if (!['http:', 'https:'].includes(parsed.protocol)) {
    throw new Error('Invalid protocol');
  }

  const blocked = await getBlockedDomains();
  if (blocked.has(parsed.hostname)) {
    return Astro.redirect('/blocked');
  }

  computedURL = parsed.toString();
} catch {
  return Astro.redirect('/404');
}

// --- Client Configuration ---
const scramjetConfig = {
  controllerUrl,
  wasmUrl: wasmPath,
  injectUrl: sjInject,
  scramjetPath,
  scope: '/scram/'
};
---

<AppLayout title="Scramjet Embed" description={`Embedded Site for ${computedURL}`}>
  <div id="status-container" class="absolute inset-0 flex items-center justify-center bg-[#111] z-50 text-white font-sans">
    <div class="text-center">
      <h1 id="status" class="text-2xl font-bold mb-2">Initializing...</h1><br />
      <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-white mx-auto"></div>
    </div>
  </div>

  <iframe id="embedFrame" class="w-full h-full border-none bg-white" data-url={computedURL} data-config={JSON.stringify(scramjetConfig)}></iframe>

  <script>
    import { LibcurlClient } from '@mercuryworkshop/libcurl-transport';
    import { registerSW } from 'virtual:pwa-register';
    import { Controller, config as sjConfig } from '@petezah-games/scramjet-controller';

    async function main() {
      const frameEl = document.getElementById('embedFrame') as HTMLIFrameElement;
      const statusEl = document.getElementById('status') as HTMLHeadingElement;
      const statusContainer = document.getElementById('status-container') as HTMLDivElement;

      if (!frameEl || !frameEl.dataset.config || !frameEl.dataset.url) {
        console.error('Missing configuration');
        return;
      }

      const targetURL = frameEl.dataset.url;
      let cfg;

      try {
        cfg = JSON.parse(frameEl.dataset.config);
      } catch (e) {
        if (statusEl) statusEl.textContent = 'Config Error';
        return;
      }

      // 1. Wisp URL Setup
      const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
      const wispUrl = `${protocol}//${window.location.host}/wisp/`;

      // 2. Scramjet Config
      sjConfig.prefix = cfg.scope;
      sjConfig.wasmPath = cfg.wasmUrl;
      sjConfig.injectPath = cfg.injectUrl;
      sjConfig.scramjetPath = cfg.scramjetPath;

      if (statusEl) statusEl.textContent = 'Connecting to Service Worker...';

      try {
        const registration = await navigator.serviceWorker.register('/scram-sw.js', {
          type: 'module',
          scope: cfg.scope
        });

        // Wait for the service worker to be ready
        if (!navigator.serviceWorker.controller) {
          statusEl.textContent = 'Waiting for service worker to activate...';
          window.location.reload();
        }

        // 4. Wait for Control (with Reload Fallback)
        // If the SW activates but doesn't claim the page fast enough, we reload to force it.
        if (!navigator.serviceWorker.controller) {
          console.log('Waiting for controller...');

          const controllerPromise = new Promise<void>((resolve) => {
            navigator.serviceWorker.addEventListener('controllerchange', () => resolve(), { once: true });
          });

          // Race: If controller doesn't appear in 1.5s, reload the page
          const timeoutPromise = new Promise((_, reject) => setTimeout(() => reject(new Error('TIMEOUT')), 15000));

          try {
            await Promise.race([controllerPromise, timeoutPromise]);
          } catch (e) {
            if (statusEl) statusEl.textContent = 'Reloading for activation...';
            window.location.reload();
            return;
          }
        }

        if (statusEl) statusEl.textContent = 'Establishing Connection...';

        // 5. Initialize Transport
        const transport = new LibcurlClient({
          wisp: wispUrl
        });

        const controller = new Controller({
          scope: cfg.scope,
          serviceworker: registration.active || registration.installing || registration.waiting,
          transport: transport
        });

        // 6. Init Controller
        await controller.wait();

        // 7. Launch
        const frame = controller.createFrame(frameEl);

        if (statusContainer) statusContainer.style.display = 'none';

        await frame.go(targetURL);
      } catch (err) {
        console.error('Proxy Error:', err);
        if (statusEl) {
          statusEl.textContent = 'Connection Failed';
          const sub = document.createElement('p');
          sub.className = 'text-sm text-red-400 mt-2';
          sub.textContent = err instanceof Error ? err.message : String(err);
          statusEl.parentElement?.appendChild(sub);
        }
      }
    }

    main();
  </script>
</AppLayout>
