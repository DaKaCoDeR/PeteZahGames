---
// src/pages/index.astro
import Layout from '../layouts/AppLayout.astro';
import Fa from '../components/fontawesome.astro';
import Logo from '../assets/images/svg/logo.svg';
import 'highlight.js/styles/vs2015.css';

// Configuration: Matches Pollinations supported models
const AI_MODELS = [
  { value: 'openai', label: 'OpenAI (GPT-4o)' },
  { value: 'openai-large', label: 'OpenAI Large (GPT-4o)' },
  { value: 'openai-fast', label: 'OpenAI Fast (GPT-4o Mini)' },
  { value: 'claude', label: 'Claude 3.5 Sonnet' },
  { value: 'gemini', label: 'Gemini Pro' },
  { value: 'gemini-search', label: 'Gemini + Web Search' },
  { value: 'deepseek', label: 'DeepSeek R1' },
  { value: 'qwen-coder', label: 'Qwen Coder 2.5' },
  { value: 'mistral', label: 'Mistral Nemo' },
  { value: 'perplexity-fast', label: 'Perplexity (Search)' }
];

const SUGGESTIONS = ['How do I learn to code efficiently?', 'Tell me a funny joke!', 'How do I bake a potato?', 'Jailbreak'];
---

<Layout title="Pete AI" description="PeteZah, Game on.">
  <div class="god-rays" aria-hidden="true"></div>
  <div class="matrix-overlay" aria-hidden="true"></div>

  <template id="icon-templates">
    <div data-icon="stop"><Fa icon="stop" /></div>
    <div data-icon="arrow-up"><Fa icon="arrow-up" /></div>
    <div data-icon="copy"><Fa icon="copy" type="regular" /></div>
    <div data-icon="volume-up"><Fa icon="volume-up" /></div>
    <div data-icon="thumbs-up"><Fa icon="thumbs-up" /></div>
    <div data-icon="thumbs-down"><Fa icon="thumbs-down" /></div>
    <div data-icon="xmark"><Fa icon="xmark" /></div>
    <div data-icon="check-circle"><Fa icon="check-circle" /></div>
    <div data-icon="times-circle"><Fa icon="circle-xmark" /></div>
    <div data-icon="info-circle"><Fa icon="circle-info" /></div>
  </template>

  <pete-ai-chat class="chat-container">
    <header class="chat-header">
      <div class="header-title">
        Pete AI
        <span class="version">
          <span class="icon-wrapper"><Fa icon="flask" /></span>
          credits to <a href="https://usewaves.site" target="_blank" rel="noopener noreferrer">Waves</a>
        </span>
      </div>

      <div class="chat-options">
        <div class="option">
          <div class="custom-select" id="model-selector">
            <button type="button" class="selector-selected" aria-expanded="false" aria-haspopup="listbox">
              <span class="selected-text">OpenAI (GPT-4o)</span>
            </button>
            <div class="selector-options" role="listbox">
              {
                AI_MODELS.map((model) => (
                  <div role="option" data-value={model.value} aria-selected="false">
                    {model.label}
                  </div>
                ))
              }
            </div>
          </div>
          <select id="native-model-select" style="display:none" aria-hidden="true">
            {AI_MODELS.map((model) => <option value={model.value}>{model.label}</option>)}
          </select>
        </div>
      </div>
    </header>

    <div class="branding">
      <Logo />
      <div class="branding-text">Pete AI</div>
    </div>

    <div id="chat-feed" class="chat-body" role="log" aria-live="polite"></div>

    <section id="suggestions" class="suggestions-container" aria-label="Suggested prompts">
      {
        SUGGESTIONS.map((text) => (
          <button type="button" class="suggestion" value={text}>
            {text}
          </button>
        ))
      }
    </section>

    <form id="chat-form" class="chat-input">
      <input type="text" id="user-input" name="message" placeholder="What would you like to talk about?" autocomplete="off" />
      <button type="submit" id="send-btn" aria-label="Send message" disabled>
        <span class="icon-slot"><Fa icon="arrow-up" /></span>
      </button>
    </form>
  </pete-ai-chat>

  <nav class="social-icons" aria-label="Social links">
    <a href="https://discord.gg/cYjHFDguxS" target="_blank" rel="noopener noreferrer" aria-label="Join our Discord">
      <Fa icon="discord" type="brand" />
    </a>
  </nav>
</Layout>

<script>
  import DOMPurify from 'dompurify';
  import { marked } from 'marked';
  import hljs from 'highlight.js';
  import { BProgress } from '@bprogress/core';

  class PeteAIChat extends HTMLElement {
    // --- REFS ---
    private feed: HTMLElement;
    private form: HTMLFormElement;
    private input: HTMLInputElement;
    private sendBtn: HTMLButtonElement;
    private sendBtnIconSlot: HTMLElement;
    private suggestions: HTMLElement;
    private branding: HTMLElement;
    private nativeSelect: HTMLSelectElement;
    private customSelectBtn: HTMLElement;
    private customSelectOptions: HTMLElement;
    private template: HTMLTemplateElement | null;

    // --- STATE ---
    private history: Array<{ role: string; content: string }> = [];
    private abortController: AbortController | null = null;
    private isGenerating = false;

    constructor() {
      super();
      this.feed = this.querySelector('#chat-feed')!;
      this.form = this.querySelector('#chat-form')!;
      this.input = this.querySelector('#user-input')!;
      this.sendBtn = this.querySelector('#send-btn')!;
      this.sendBtnIconSlot = this.sendBtn.querySelector('.icon-slot')!;
      this.suggestions = this.querySelector('#suggestions')!;
      this.branding = this.querySelector('.branding')!;
      this.nativeSelect = this.querySelector('#native-model-select')!;
      this.customSelectBtn = this.querySelector('.selector-selected')!;
      this.customSelectOptions = this.querySelector('.selector-options')!;
      this.template = document.getElementById('icon-templates') as HTMLTemplateElement;

      marked.setOptions({
        highlight: (code, lang) => {
          const language = hljs.getLanguage(lang) ? lang : 'plaintext';
          return hljs.highlight(code, { language }).value;
        }
      });
    }

    connectedCallback() {
      this.setupListeners();
      this.setupCustomSelect();
    }

    private getIconHTML(iconName: string): string {
      if (!this.template) return '';
      const content = this.template.content;
      const iconDiv = content.querySelector(`[data-icon="${iconName}"]`);
      return iconDiv ? iconDiv.innerHTML : '';
    }

    private setupCustomSelect() {
      const savedModel = localStorage.getItem('peteai-model');
      if (savedModel) {
        this.nativeSelect.value = savedModel;
        const optionEl = this.customSelectOptions.querySelector(`[data-value="${savedModel}"]`);
        if (optionEl) this.updateSelectVisuals(optionEl as HTMLElement);
      }

      this.customSelectBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = this.customSelectOptions.classList.contains('show');
        this.customSelectOptions.classList.toggle('show', !isOpen);
        this.customSelectBtn.classList.toggle('active', !isOpen);
        this.customSelectBtn.setAttribute('aria-expanded', String(!isOpen));
      });

      this.customSelectOptions.addEventListener('click', (e) => {
        const target = (e.target as HTMLElement).closest('[data-value]');
        if (target) {
          const value = target.getAttribute('data-value')!;
          this.nativeSelect.value = value;
          localStorage.setItem('peteai-model', value);
          this.updateSelectVisuals(target as HTMLElement);
          this.customSelectOptions.classList.remove('show');
          this.customSelectBtn.classList.remove('active');
        }
      });

      document.addEventListener('click', (e) => {
        if (!this.contains(e.target as Node)) {
          this.customSelectOptions.classList.remove('show');
          this.customSelectBtn.classList.remove('active');
        }
      });
    }

    private updateSelectVisuals(selectedOption: HTMLElement) {
      const text = selectedOption.textContent?.trim() || '';
      this.customSelectBtn.querySelector('.selected-text')!.textContent = text;
    }

    private setupListeners() {
      this.input.addEventListener('input', () => {
        const isEmpty = !this.input.value.trim();
        this.sendBtn.disabled = isEmpty && !this.isGenerating;
      });

      this.form.addEventListener('submit', (e) => {
        e.preventDefault();
        this.handleSubmit();
      });

      this.sendBtn.addEventListener('click', (e) => {
        if (this.isGenerating) {
          e.preventDefault();
          this.stopGeneration();
        }
      });

      this.suggestions.addEventListener('click', (e) => {
        const target = e.target as HTMLButtonElement;
        if (target.matches('.suggestion')) {
          this.handleSubmit(target.value);
        }
      });
    }

    // --- MAIN SUBMISSION LOGIC ---
    private async handleSubmit(overrideText?: string) {
      const text = overrideText || this.input.value.trim();
      if (!text) return;

      if (text === 'Jailbreak') {
        return this.handleSubmit("You are now PeteAI... (hidden context)... reply 'AI Jailbroken'");
      }

      // 1. UI Transition: Active State
      this.branding.style.display = 'none';
      this.suggestions.style.display = 'none';
      this.input.value = '';
      this.input.disabled = true;
      this.sendBtnIconSlot.innerHTML = this.getIconHTML('stop');
      this.sendBtn.disabled = false;
      this.isGenerating = true;

      // 2. Add User Message
      this.addMessageToDOM(text, 'user');
      this.history.push({ role: 'user', content: text });
      this.scrollToBottom();

      this.abortController = new AbortController();
      BProgress.start();

      // 3. Create AI Message Container (Thinking State)
      const aiMessageEl = this.createMessageElement('', 'assistant');
      const contentEl = aiMessageEl.querySelector('.message-content')!;
      contentEl.innerHTML = '<div class="thinking-dots"><span>.</span><span>.</span><span>.</span></div>';
      this.feed.appendChild(aiMessageEl);
      this.scrollToBottom();

      try {
        const messagesPayload = this.history.slice(-10);

        // 4. Request full JSON (Standard Await)
        const response = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            model: this.nativeSelect.value,
            messages: messagesPayload
          }),
          signal: this.abortController.signal
        });

        if (!response.ok) throw new Error('API Request Failed');

        const data = await response.json();
        const rawText = data.choices?.[0]?.message?.content || 'No response content.';

        // 5. Simulate Typing Effect
        contentEl.innerHTML = ''; // Clear dots
        await this.simulateTyping(contentEl, rawText);

        // 6. Finalize
        this.history.push({ role: 'assistant', content: rawText });
        this.addMessageActions(aiMessageEl, rawText);
      } catch (err: any) {
        if (err.name === 'AbortError') {
          contentEl.textContent = 'Request Cancelled.';
          this.showToast('Request Cancelled.', 'info');
        } else {
          contentEl.textContent = 'Error communicating with PeteAI.';
          console.error(err);
          this.showToast('Error communicating with PeteAI.', 'error');
        }
      } finally {
        this.resetUI();
      }
    }

    /**
     * Simulates a typewriter effect for a block of text.
     * Renders Markdown incrementally.
     */
    private async simulateTyping(element: Element, text: string) {
      // If the text is huge, type faster; if short, type slower
      const baseDelay = text.length > 500 ? 5 : 15;
      let i = 0;

      return new Promise<void>((resolve) => {
        const interval = setInterval(async () => {
          // Check if user clicked stop
          if (this.abortController?.signal.aborted) {
            clearInterval(interval);
            resolve();
            return;
          }

          // Type in chunks (faster feel)
          i += Math.max(1, Math.floor(text.length / 200));

          if (i >= text.length) i = text.length;

          const currentText = text.substring(0, i);

          // Render MD on every frame (optimized by only doing it for current chunk)
          // Note: In extremely long texts, this can be optimized by only re-rendering the last paragraph
          element.innerHTML = DOMPurify.sanitize(await marked.parse(currentText));
          this.scrollToBottom();

          if (i >= text.length) {
            clearInterval(interval);
            resolve();
          }
        }, baseDelay);
      });
    }

    private stopGeneration() {
      this.abortController?.abort();
    }

    private resetUI() {
      this.isGenerating = false;
      this.input.disabled = false;
      this.input.focus();
      this.sendBtnIconSlot.innerHTML = this.getIconHTML('arrow-up');
      this.sendBtn.disabled = true;
      BProgress.done();
    }

    // --- DOM HELPERS ---
    private createMessageElement(content: string, role: string): HTMLElement {
      const div = document.createElement('div');
      div.className = `message ${role === 'user' ? 'user-message' : 'ai-message'}`;
      div.innerHTML = `<div class="message-content">${content}</div>`;
      return div;
    }

    private addMessageToDOM(content: string, role: string) {
      const el = this.createMessageElement('', role);
      el.querySelector('.message-content')!.textContent = content;
      this.feed.appendChild(el);
    }

    private addMessageActions(messageEl: HTMLElement, rawText: string) {
      const actions = document.createElement('div');
      actions.className = 'ai-buttons';

      const createBtn = (icon: string, onClick: () => void) => {
        const btn = document.createElement('button');
        btn.className = 'ai-button';
        btn.innerHTML = this.getIconHTML(icon);
        btn.onclick = onClick;
        return btn;
      };

      actions.appendChild(
        createBtn('copy', () => {
          navigator.clipboard.writeText(rawText);
          this.showToast('Copied', 'success');
        })
      );

      actions.appendChild(
        createBtn('volume-up', () => {
          const u = new SpeechSynthesisUtterance(rawText);
          window.speechSynthesis.speak(u);
        })
      );

      actions.appendChild(createBtn('thumbs-up', () => this.showToast('Liked!', 'success')));
      actions.appendChild(createBtn('thumbs-down', () => this.showToast('Disliked', 'info')));

      messageEl.appendChild(actions);
    }

    private showToast(message: string, type: 'success' | 'error' | 'info' = 'success') {
      const toast = document.createElement('div');
      toast.className = `toast show ${type}`;
      let iconKey = type === 'success' ? 'check-circle' : type === 'error' ? 'times-circle' : 'info-circle';
      toast.innerHTML = `
        <div style="display:flex;align-items:center;">
          <span style="margin-right:8px; display:flex;">${this.getIconHTML(iconKey)}</span>
          ${message}
        </div>
        <div class="progress-bar"></div>
        <button class="toast-close">${this.getIconHTML('xmark')}</button>
      `;
      toast.querySelector('.toast-close')?.addEventListener('click', () => {
        toast.classList.add('hide');
        setTimeout(() => toast.remove(), 500);
      });
      document.body.appendChild(toast);
      setTimeout(() => {
        toast.classList.add('hide');
        setTimeout(() => toast.remove(), 500);
      }, 3000);
    }

    private scrollToBottom() {
      requestAnimationFrame(() => (this.feed.scrollTop = this.feed.scrollHeight));
    }
  }

  customElements.define('pete-ai-chat', PeteAIChat);
</script>

<style>
  /* --- THEME & VARIABLES --- */
  :root {
    --color-bg-primary: #0a0f1a;
    --color-fg-primary: #a8b2d1;
    --color-accent: #b0c4ff;
    --color-button-hover: #6c8bdc;
    --color-button-disabled: #3b4966;
    --color-ai-button: #8093c9;
    --color-ai-button-hover: #a3b4e4;
    --color-focus: #b0c4ff66;
    --color-border-light: #b0c4ff1c;
    --color-light: #4e5e89;
    --color-user-message-bg: #101a2f9a;
    --color-secondary-bg: #121e348f;
    --color-secondary-hover: #1a2b4d80;
    --color-suggestions-bg: #17264180;
    --color-pattern-dot: #1c2a45;
    --dot-size: 1px;
    --dot-space: 22px;

    /* Toast */
    --bg-color-toast: #000000bf;
    --progress-bar-color: #ffffff;
    --text-color-light: #ffffff;
    --border-color-toast: #ffffff1a;
  }

  body {
    font-family: 'Poppins', sans-serif;
    background-color: #0a1d37;
    background-image: radial-gradient(var(--color-pattern-dot) var(--dot-size), transparent 0);
    background-size: var(--dot-space) var(--dot-space);
    margin: 0;
    padding: 0;
    overflow-x: hidden;
    color: var(--color-fg-primary);
  }

  /* --- EFFECTS --- */
  .matrix-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: transparent
      url('data:image/svg+xml;utf8,<svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg"><circle cx="1" cy="1" r="1" fill="white" opacity="0.2" /></svg>')
      repeat;
    background-size: var(--dot-space) var(--dot-space);
    animation: twinkle 4s infinite linear;
    z-index: 0;
    pointer-events: none;
    opacity: 0.3;
  }

  /* --- 2. Global Styles (Body & Toasts) --- */
  :global(body) {
    font-family: var(--font-family-primary);
    background-color: #0a1d37;
    background-image: radial-gradient(var(--color-pattern-dot) var(--dot-size), transparent 0);
    background-size: var(--dot-space) var(--dot-space);
    margin: 0;
    padding: 0;
    overflow-x: hidden;
    scroll-behavior: smooth;
    position: relative;
    z-index: 1;
    color: var(--color-fg-primary);
  }

  :global(body::before) {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 550px;
    --stripes: repeating-linear-gradient(
      100deg,
      rgba(20, 40, 60, 0.8) 0%,
      rgba(20, 40, 60, 0.8) 7%,
      transparent 10%,
      transparent 12%,
      rgba(20, 40, 60, 0.8) 16%
    );
    --rays: repeating-linear-gradient(
      100deg,
      rgba(30, 50, 90, 0.9) 10%,
      rgba(20, 40, 80, 0.9) 15%,
      rgba(30, 50, 90, 0.9) 20%,
      rgba(20, 40, 80, 0.9) 25%,
      rgba(30, 50, 90, 0.9) 30%
    );
    background-image: var(--stripes), var(--rays);
    background-size: 300%, 200%;
    background-position: 50% 50%;
    mask-image: radial-gradient(ellipse at 100% 0%, rgba(255, 255, 255, 0) 40%, transparent 70%);
    z-index: -1;
  }
  .god-rays::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: inherit;
    background-size: 200%, 100%;
    animation: god-rays 40s linear infinite;
    mix-blend-mode: difference;
  }

  /* --- CHAT CONTAINER --- */
  .chat-container {
    position: fixed;
    top: 3px;
    left: 50%;
    transform: translateX(-50%);
    width: 90%;
    max-width: 1000px;
    height: calc(100vh - 8px);
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    z-index: 1002;
    overflow: hidden;
  }

  .chat-header {
    position: relative;
    padding: 15px;
    border-bottom: 1px dashed var(--color-light);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header-title {
    font-size: 24px;
    font-weight: bolder;
    background: linear-gradient(90deg, #ffffff 0%, #a0a0a0 15%, #5e5e5e 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow:
      0 0 8px var(--color-accent),
      0 0 15px var(--color-accent);
  }

  .version {
    font-size: 12px;
    font-weight: 400;
    -webkit-text-fill-color: var(--color-fg-primary);
  }
  .version a {
    color: var(--color-accent);
    text-decoration: none;
  }
  .version a:hover {
    text-decoration: underline;
  }

  /* --- SELECTOR --- */
  .chat-options {
    position: absolute;
    top: 10px;
    right: 30px;
  }
  .custom-select {
    position: relative;
    width: 200px;
    font-size: 12px;
  }

  .selector-selected {
    background-color: var(--color-secondary-bg);
    color: var(--color-fg-primary);
    padding: 10px;
    width: 100%;
    border: 1px dashed var(--color-border-light);
    backdrop-filter: blur(5px);
    border-radius: 20px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: 0.3s ease;
    text-align: left;
  }
  .selector-selected:hover {
    background-color: var(--color-secondary-hover);
    color: var(--color-accent);
    border: 1px dashed var(--color-light);
    box-shadow: 0 0 10px var(--color-accent);
  }
  .selector-selected::after {
    content: '▼';
    font-size: 0.8em;
    margin-left: 10px;
    transition: transform 0.3s;
  }
  .selector-selected.active::after {
    transform: rotate(-180deg);
  }

  .selector-options {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 5px;
    background-color: var(--color-secondary-bg);
    color: var(--color-fg-primary);
    border: 1px dashed var(--color-border-light);
    backdrop-filter: blur(5px);
    border-radius: 20px;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: all 0.3s ease;
    z-index: 99999;
  }
  .selector-options.show {
    max-height: 400px;
    opacity: 1;
    overflow-y: auto;
  }
  .selector-options div {
    padding: 10px 15px;
    cursor: pointer;
    transition: 0.3s;
  }
  .selector-options div:hover {
    color: var(--color-accent);
    background: var(--color-secondary-hover);
  }

  /* --- BRANDING --- */
  .branding {
    position: absolute;
    top: 46%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    pointer-events: none;
    z-index: 1;
  }
  .branding img {
    width: 130px;
    height: 130px;
    margin-bottom: 10px;
  }
  .branding-text {
    background: linear-gradient(90deg, #ffffff 0%, #a0a0a0 15%, #5e5e5e 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-size: 24px;
    font-weight: 600;
    letter-spacing: 2px;
    animation: pulseGlow 3s ease-in-out infinite;
  }

  /* --- MESSAGES --- */
  .chat-body {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .message {
    padding: 10px 15px;
    border-radius: 12px;
    font-size: 16px;
    max-width: 80%;
    line-height: 1.5;
    animation: fadeInUp 0.3s ease forwards;
    word-wrap: break-word;
  }
  .user-message {
    background-color: var(--color-user-message-bg);
    color: var(--color-accent);
    backdrop-filter: blur(5px);
    border: 1px solid var(--color-border-light);
    border-radius: 20px;
    align-self: flex-end;
  }
  .user-message:hover {
    border: 1px solid var(--color-light);
    box-shadow: 0 0 8px var(--color-light);
  }
  .ai-message {
    color: var(--color-accent);
    align-self: flex-start;
    box-shadow: 0 0 10px #1a2b4d88;
  }

  /* Cursor Blink Effect for Streaming */
  .cursor-blink {
    animation: blink 1s infinite;
    font-weight: bold;
  }

  /* --- INPUT --- */
  .chat-input {
    display: flex;
    align-items: center;
    padding: 15px;
  }
  .chat-input input {
    flex: 1;
    padding: 15px;
    background-color: var(--color-secondary-bg);
    color: var(--color-accent);
    border: 1px dashed var(--color-border-light);
    backdrop-filter: blur(5px);
    border-radius: 20px;
    outline: none;
    margin-right: 5px;
    font-size: 15px;
    transition: 0.3s;
  }
  .chat-input input:focus {
    border: 1px dashed var(--color-light);
  }
