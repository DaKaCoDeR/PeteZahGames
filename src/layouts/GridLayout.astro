---
import { Picture } from 'astro:assets';
import collectionData from '../data/games.json';
import AppLayout from '../layouts/AppLayout.astro';

// --- TYPE DEFINITIONS ---
interface RawCollectionItem {
  label: string;
  url: string;
  img?: string;
  imageUrl?: string;
  categories?: string[];
  width?: number | string;
  height?: number | string;
  style?: Record<string, string>;
}

interface Props {
  title?: string;
  description?: string;
  collection?: 'games' | 'apps';
}

const { title = 'PeteZah | Games', description = 'Pete Zah, game on', collection = 'games' } = Astro.props;

// --- ASSET RESOLUTION ---
const allAssets = import.meta.glob<{ default: ImageMetadata }>('../assets/images/**/*.{png,jpg,jpeg,webp,avif,svg}', { eager: true });

const assetMap = new Map<string, ImageMetadata>();
for (const [path, module] of Object.entries(allAssets)) {
  const fileName = path.split('/').pop();
  if (fileName) assetMap.set(fileName, module.default);
}

// --- DATA PROCESSING ---
const rawItems = (collectionData[collection] || []) as RawCollectionItem[];

// Extract unique categories for the filter bar
const allCategories = ['All', ...new Set(rawItems.flatMap((i) => i.categories || []).map((c) => c.toLowerCase()))];
// Limit to the ones in your design + generic ones if needed
const displayCategories = ['All', 'Action', 'Racing', 'Strategy', 'Sports', 'Skill', 'Shooting', '2 Player', 'Io'];

const processedItems = rawItems.map((item) => {
  const rawImg = item.img || item.imageUrl || '';
  const fileName = rawImg.split('/').pop() || '';
  const isExternal = rawImg.startsWith('http');
  const localAsset = !isExternal ? assetMap.get(fileName) : undefined;

  const href = item.url.startsWith('http') ? `/play/embed/${encodeURIComponent(item.url)}` : `/play/${item.url.replace(/^\/+/, '')}`;

  return {
    ...item,
    href,
    isExternal,
    localAsset,
    // Join all categories for easier filtering in JS
    categoryString: (item.categories || []).join(' ').toLowerCase()
  };
});
---

<AppLayout title={title} description={description}>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" slot="head" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" slot="head" />

  <div class="god-rays" aria-hidden="true"></div>

  <button class="randomGameOpensBtn" id="randomBtn" aria-label="Play Random Game">
    <i class="fas fa-dice" aria-hidden="true"></i>
    Random Game
  </button>

  <button class="add-game-btn" id="addGameBtn" aria-label="Add Custom Game">
    <i class="fas fa-plus" aria-hidden="true"></i>
    Add Game
  </button>

  <search class="search-container">
    <input type="text" id="search-games" list="game-list" placeholder="Search games..." autocomplete="off" />
    <datalist id="game-list">
      {processedItems.map((item) => <option value={item.label} />)}
    </datalist>
  </search>

  <nav class="category-container" aria-label="Game Categories">
    {
      displayCategories.map((cat, index) => (
        <button class={`category-btn ${index === 0 ? 'active' : ''}`} data-category={cat === 'All' ? '' : cat.toLowerCase()}>
          {cat}
        </button>
      ))
    }
  </nav>

  <section class="game-container" id="imageContainer">
    {
      processedItems.map((item, index) => {
        // PERF: Eager load top 8 items
        const isPriority = index < 8;
        const loading = isPriority ? 'eager' : 'lazy';

        return (
          <figure class="image-item" data-label={item.label.toLowerCase()} data-categories={item.categoryString}>
            {/* Favorite Badge (Visual only based on reference) */}
            <div class="favorite-badge">
              <i class="fas fa-star" /> Favorite
            </div>

            {/* Options Menu Trigger */}
            <div class="game-options" role="button" aria-label="Game Options">
              <i class="fas fa-cog" />
            </div>

            <a href={item.href} aria-label={`Play ${item.label}`}>
              {item.localAsset ? (
                <Picture
                  src={item.localAsset}
                  widths={[200, 400]}
                  sizes="(max-width: 600px) 100vw, 200px"
                  alt=""
                  loading={loading}
                  fetchpriority={isPriority ? 'high' : 'auto'}
                  formats={['avif', 'webp']}
                />
              ) : (
                <img src={item.img || item.imageUrl} alt="" loading={loading} />
              )}
            </a>

            <figcaption class="label">{item.label}</figcaption>
          </figure>
        );
      })
    }
  </section>

  <div id="addGamePopup" class="popup-overlay" aria-hidden="true">
    <div class="popup-content">
      <div class="popup-header">
        <h2>Add Custom Game</h2>
        <button class="popup-close">&times;</button>
      </div>
      <form id="addGameForm" onsubmit="event.preventDefault();">
        <div class="form-group">
          <label for="gameTitle">Game Title</label>
          <input type="text" id="gameTitle" required placeholder="Enter game name" />
        </div>
        <div class="form-group">
          <label for="gameUrl">Game URL</label>
          <input type="url" id="gameUrl" required placeholder="https://example.com/game" />
        </div>
        <div class="form-group">
          <label for="gameImage">Game Image</label>
          <input type="file" id="gameImage" required accept="image/*" />
        </div>
        <button type="submit" class="submit-btn">Add Game</button>
      </form>
    </div>
  </div>
</AppLayout>

<style is:global>
  /* --- GLOBAL STYLES ---
    Exact port of provided CSS with font fixes
  */

  :root {
    --primary-gradient: linear-gradient(90deg, #2e6b4f, #3e8c65); /* Fallback */
    --hover-gradient: linear-gradient(90deg, #1f4a3a, #2e6b4f);
  }

  body {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    min-height: 100vh;
    margin: 0;
    background-color: #0a1d37;
    color: #fff;
    font-family:
      'Inter',
      -apple-system,
      BlinkMacSystemFont,
      sans-serif;
    padding: 0;
    overflow-x: hidden;
    overflow-y: auto;
    transition:
      background-color 0.5s,
      color 0.5s;
  }

  body::-webkit-scrollbar {
    display: none;
  }

  /* GOD RAYS */
  .god-rays {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 550px;
    --stripes: repeating-linear-gradient(
      100deg,
      rgba(20, 40, 60, 0.8) 0%,
      rgba(20, 40, 60, 0.8) 7%,
      transparent 10%,
      transparent 12%,
      rgba(20, 40, 60, 0.8) 16%
    );
    --rays: repeating-linear-gradient(
      100deg,
      rgba(30, 50, 90, 0.9) 10%,
      rgba(20, 40, 80, 0.9) 15%,
      rgba(30, 50, 90, 0.9) 20%,
      rgba(20, 40, 80, 0.9) 25%,
      rgba(30, 50, 90, 0.9) 30%
    );
    background-image: var(--stripes), var(--rays);
    background-size: 300%, 200%;
    background-position:
      50% 50%,
      50% 50%;
    animation: 2s fadeIn;
    mask-image: radial-gradient(ellipse at 100% 0%, rgba(255, 255, 255, 0) 40%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at 100% 0%, white 40%, transparent 70%);
    pointer-events: none;
    z-index: -1;
  }
  .god-rays::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--stripes), var(--rays);
    background-size: 200%, 100%;
    animation: 40s linear infinite god-rays;
    background-attachment: fixed;
    mix-blend-mode: difference;
  }

  /* SEARCH */
  .search-container {
    position: fixed;
    top: 26px;
    left: 0;
    width: 100%;
    text-align: center;
    z-index: 1000;
    padding: 0;
    display: flex;
    justify-content: center;
  }
  .search-container input {
    font-family: 'Inter', sans-serif;
    width: 42vw;
    max-width: 520px;
    padding: 10px 22px;
    font-size: 14px;
    font-weight: 400;
    border: 2px solid rgba(255, 255, 255, 0.25);
    color: #fff;
    background: #151a2d;
    border-radius: 50px;
    transition: 0.3s;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(10px);
  }
  .search-container input:focus {
    background: rgba(5, 15, 28, 0.95);
    outline: 0;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
    border-color: #fff;
    padding-left: 52px;
    padding-right: 52px;
    transform: translateY(-2px);
  }

  /* CATEGORIES */
  .category-container {
    position: fixed;
    top: 82px;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: center;
    gap: 12px;
    z-index: 999;
    padding: 10px 20px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .category-container::-webkit-scrollbar {
    display: none;
  }

  .category-btn {
    padding: 9px 20px;
    background: #151a2d;
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.25);
    border-radius: 20px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    font-family: 'Inter', sans-serif;
    white-space: nowrap;
    transition: 0.3s;
    backdrop-filter: blur(8px);
  }
  .category-btn:hover {
    background: rgba(5, 15, 28, 0.95);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
    transform: translateY(-3px);
    border-color: #fff;
  }
  .category-btn.active {
    background: rgba(5, 15, 28, 0.95);
    border-color: #fff;
    box-shadow: 0 4px 16px rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  /* GRID & CARDS */
  .game-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 20px;
    width: 100%;
    max-width: 100%;
    padding: 150px 15px 30px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .image-item {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: 75%;
    overflow: hidden;
    transition: 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    border-radius: 16px;
    margin: 0;
    animation: 0.5s ease-out forwards slideInFromLeft;
    background-color: transparent;
    border: 3px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.4);
    cursor: pointer;
  }
  .image-item:hover {
    z-index: 2;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
    filter: brightness(1.08) contrast(1.2);
    transform: scale(1.4) translateY(-8px);
    border-color: rgba(255, 255, 255, 0.6);
    border-width: 2px;
  }

  /* Link & Image handling */
  .image-item a {
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
    border-radius: 16px;
    pointer-events: none;
  }
  .image-item img,
  .image-item picture,
  .image-item picture img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 13px;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .image-item:hover img {
    transform: scale(1.4);
  }

  /* Label */
  .image-item .label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: 0 0;
    color: #fff;
    text-align: center;
    padding: 28px 12px 8px;
    border-bottom-left-radius: 16px;
    border-bottom-right-radius: 16px;
    font-size: 13px;
    font-weight: 600;
    opacity: 0;
    transition: 0.3s;
    pointer-events: none;
  }
  .image-item:hover .label {
    opacity: 1;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.9), transparent);
  }

  /* BUTTONS */
  .add-game-btn,
  .randomGameOpensBtn {
    position: fixed;
    top: 24px;
    z-index: 9999;
    padding: 10px 20px;
    background: #151a2d;
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.25);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
    border-radius: 16px;
    font-family: 'Inter', sans-serif;
    transition: 0.3s;
    display: flex;
    align-items: center;
    gap: 8px;
    backdrop-filter: blur(10px);
  }
  .randomGameOpensBtn {
    left: 20px;
  }
  .add-game-btn {
    right: 20px;
  }
  .add-game-btn:hover,
  .randomGameOpensBtn:hover {
    transform: scale(1.08) translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.5);
    background: rgba(5, 15, 28, 0.95);
    border-color: #fff;
  }

  /* POPUP STYLES */
  .popup-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
    z-index: 10000;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(5px);
  }
  .popup-overlay.active {
    display: flex;
  }
  .popup-content {
    background: rgba(10, 29, 55, 0.95);
    border: 2px solid rgba(255, 255, 255, 0.25);
    border-radius: 20px;
    padding: 28px;
    max-width: 500px;
    width: 90%;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.9);
    animation: 0.3s popupSlideIn;
    backdrop-filter: blur(15px);
  }
  .popup-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 22px;
  }
  .popup-header h2 {
    margin: 0;
    font-size: 22px;
    font-weight: 600;
    color: #fff;
  }
  .popup-close {
    background: 0 0;
    border: none;
    color: #fff;
    font-size: 28px;
    cursor: pointer;
  }

  .form-group {
    margin-bottom: 18px;
  }
  .form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 500;
    font-size: 14px;
    color: #fff;
  }
  .form-group input {
    width: 100%;
    padding: 12px 16px;
    border: 2px solid rgba(255, 255, 255, 0.25);
    background: rgba(10, 29, 55, 0.6);
    color: #fff;
    border-radius: 12px;
  }
  .submit-btn {
    width: 100%;
    padding: 14px;
    background: rgba(10, 29, 55, 0.6);
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.25);
    border-radius: 12px;
  }

  /* OVERLAY ICONS (Visual Identity) */
  .game-options {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 32px;
    height: 32px;
    background: rgba(10, 29, 55, 0.9);
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: 0.3s;
    z-index: 10;
    backdrop-filter: blur(8px);
  }
  .image-item:hover .game-options {
    opacity: 1;
  }
  .game-options i {
    font-size: 13px;
    color: #fff;
  }

  .favorite-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    background: rgba(255, 215, 0, 0.95);
    color: #000;
    padding: 5px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
    display: none;
    align-items: center;
    gap: 4px;
    backdrop-filter: blur(5px);
    border: 2px solid rgba(255, 215, 0, 0.5);
  }
  .image-item.favorited .favorite-badge {
    display: flex;
  }

  /* KEYFRAMES */
  @keyframes slideInFromLeft {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @keyframes god-rays {
    0% {
      background-position: 0% 0%;
    }
    100% {
      background-position: 100% 100%;
    }
  }
  @keyframes popupSlideIn {
    from {
      opacity: 0;
      transform: scale(0.9) translateY(-20px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
</style>

<script>
  // CLIENT SIDE LOGIC
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search-games') as HTMLInputElement;
    const categoryBtns = document.querySelectorAll('.category-btn');
    const items = Array.from(document.querySelectorAll('.image-item'));
    const randomBtn = document.getElementById('randomBtn');
    const addGameBtn = document.getElementById('addGameBtn');
    const popupOverlay = document.getElementById('addGamePopup');
    const closePopupBtn = document.querySelector('.popup-close');

    let currentCategory = '';
    let currentSearch = '';

    // --- FILTER LOGIC ---
    function applyFilters() {
      requestAnimationFrame(() => {
        items.forEach((item) => {
          const el = item as HTMLElement;
          const label = el.dataset.label || '';
          const cats = el.dataset.categories || '';

          const matchesSearch = label.includes(currentSearch);
          const matchesCategory = currentCategory === '' || cats.includes(currentCategory);

          el.style.display = matchesSearch && matchesCategory ? '' : 'none';
        });
      });
    }

    // Search Input
    searchInput?.addEventListener('input', (e) => {
      currentSearch = (e.target as HTMLInputElement).value.toLowerCase();
      applyFilters();
    });

    // Category Buttons
    categoryBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        // Update Active State
        categoryBtns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');

        // Update Filter
        currentCategory = (btn as HTMLElement).dataset.category || '';
        applyFilters();
      });
    });

    // Random Game Logic
    randomBtn?.addEventListener('click', () => {
      const visibleItems = items.filter((i) => (i as HTMLElement).style.display !== 'none');
      if (visibleItems.length > 0) {
        const randomIndex = Math.floor(Math.random() * visibleItems.length);
        const link = visibleItems[randomIndex].querySelector('a');
        link?.click();
      }
    });

    // Popup Logic (Visual Only)
    const togglePopup = (show: boolean) => {
      if (popupOverlay) {
        if (show) popupOverlay.classList.add('active');
        else popupOverlay.classList.remove('active');
      }
    };

    addGameBtn?.addEventListener('click', () => togglePopup(true));
    closePopupBtn?.addEventListener('click', () => togglePopup(false));
    popupOverlay?.addEventListener('click', (e) => {
      if (e.target === popupOverlay) togglePopup(false);
    });
  });
</script>
=
